# Postgres connection string (Neon, Supabase, or local).
DATABASE_URL="postgres://user:password@host:5432/database"

# Public URL of the app. Better Auth builds OAuth callback URLs from this,
# so a wrong value causes redirect_uri_mismatch from Google.
BETTER_AUTH_URL="http://localhost:3000"

# Secret used to sign sessions. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email delivery for magic links. Without RESEND_API_KEY the sign-in link is
# printed to the server console instead, which is fine for local development.
RESEND_API_KEY=""
EMAIL_FROM="Thrift Flux <onboarding@resend.dev>"

# Razorpay — https://dashboard.razorpay.com/app/website-app-settings/api-keys
# Switch the dashboard to Test Mode first; test keys start with rzp_test_.
# The key id reaches the browser (it has to, to open the checkout widget); the
# secret must stay server-side, which is why it has no NEXT_PUBLIC_ prefix.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
